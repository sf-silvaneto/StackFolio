generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Se estiver usando SQLite, tools String[] vai dar erro, me avise se for o caso.
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  password  String?   // Opcional para quem loga com Google
  googleId  String?   @unique
  picture   String?
  
  // Informações do perfil
  nickname  String?   @unique
  bio       String?
  tools     String[]  // Requer PostgreSQL (Array de strings)

  // === NOVOS CAMPOS DE CONFIGURAÇÕES (SETTINGS) ===
  customLink          String?  @unique
  altEmail            String?
  primaryEmailChoice  String?  @default("google") // "google" ou "alternative"
  phone               String?
  isWhatsApp          Boolean  @default(false)
  github              String?
  linkedin            String?

  // === CAMPOS DE PRIVACIDADE ===
  profileVisibility   Boolean  @default(true)
  publicEmail         Boolean  @default(true)
  showLocation        Boolean  @default(true)
  showSocial          Boolean  @default(true)

  // Relacionamentos
  projects  Project[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}